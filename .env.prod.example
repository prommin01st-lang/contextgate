# ============================================================
# ContextGate — Production Environment Template
# ============================================================
#
# Copy this file to `.env` on the production server, fill in values,
# and chmod 600 to protect secrets.
#
# Generate secure random values:
#   openssl rand -base64 48     (for JWT_SECRET)
#   openssl rand -hex 32        (for DB / Redis passwords)
# ============================================================

# ─── Domains ────────────────────────────────────────────────
# Set DNS A records for both domains pointing to your server IP.
APP_DOMAIN=app.example.com
API_DOMAIN=mcp.example.com

# Email for Let's Encrypt notifications (cert renewal failures, etc.)
ACME_EMAIL=admin@example.com

# ─── Frontend build-time API URL ────────────────────────────
# Used at dashboard build time. Must match API_DOMAIN with https://.
VITE_API_URL=https://mcp.example.com

# CORS allowlist for the API server (full URL, no trailing slash)
CORS_ORIGIN=https://app.example.com

# ─── Database ───────────────────────────────────────────────
DB_USER=contextgate
DB_PASSWORD=                    # openssl rand -hex 32
DB_NAME=contextgate

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=                 # openssl rand -hex 32

# ─── Auth secrets ───────────────────────────────────────────
# 256-bit minimum. ROTATE periodically; rotation invalidates all
# existing JWT tokens (users will need to log in again).
JWT_SECRET=                     # openssl rand -base64 48

# ─── Image version (used by docker-compose.prod.yml) ────────
VERSION=0.1.0
