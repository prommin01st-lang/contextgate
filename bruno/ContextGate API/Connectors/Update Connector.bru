meta {
  name: Update Connector
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/connectors/{{connectorId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Updated Files",
    "config": {
      "rootPath": "/data/files",
      "allowedExtensions": [".txt", ".md", ".json", ".csv"]
    }
  }
}
