# ==========================================
# ContextGate - Environment Configuration
# ==========================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contextgate

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
API_AUTH_KEY=your-api-auth-key

# Server
PORT=8899
NODE_ENV=development

# Dashboard (Vite build-time variable)
VITE_API_URL=http://localhost:8899

# Encryption
CREDENTIAL_MASTER_KEY=your-32-byte-master-key-here!!
